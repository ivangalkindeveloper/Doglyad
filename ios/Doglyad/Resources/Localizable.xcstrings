    "onBoardingDescriptionFifth" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Next, scan the patient: take a photo of the ultrasound report, fill in the patient information, describe the study, and submit it to see the model's response."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Далее сканируйте пациента: делайте фото ультра-звукового исследования, заполняйте данные пациента, описывайте проведенное исследования и отправляйте, чтобы увидеть ответ генерации модели."
          }
        }
      }
    },
    "onBoardingDescriptionFirst" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doglyad - an AI-assistant that generates ultrasound conclusions based on collected patient data. The conclusion is generated by a specialized LLM model trained on large-scale medical examination data."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Догляд - ИИ-ассистент, который генерирует заключения УЗИ на основе собранных данных о пациентах. Заключение генерируется специализированной моделью LLM, обученной на данных крупномасштабного медицинского обследования."
          }
        }
      }
    },
    "onBoardingDescriptionFourth" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To get started, first select the ultrasound type."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для того чтобы начать работу сначала выберите тип ультразвукового исследования."
          }
        }
      }
    },
    "onBoardingDescriptionSecond" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The application is intended solely for use by qualified medical professionals and is not intended for use by patients or individuals without appropriate medical training."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приложение предназначено исключительно для использования квалифицированными медицинскими специалистами и не предназначено для использования пациентами или лицами без соответствующего медицинского образования."
          }
        }
      }
    },
    "onBoardingDescriptionThird" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The app uses artificial intelligence models to generate medical reports. The generated results are for informational and advisory purposes only.\nPlease read and accept the app's terms of use."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Приложение использует модели искусственного интеллекта для генерации медицинских заключений. Результаты генерации носят исключительно рекомендательный и вспомогательный характер.\nПожалуйста ознакомьтесь и примите условия использования приложением."
          }
        }
      }
    },
