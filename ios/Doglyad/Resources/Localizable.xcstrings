    "neuralModelTemplateExampleDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Based on the ultrasound data provided:\n\nOrgan(s) under examination: {{organ}}\nPosition and contours: {{position_and_contours}}\nDimensions: {{sizes}}\nEchostructure: {{echogenicity}}\nFocal lesions: {{lesions}}\n\nConclusion:\nUltrasound features: {{diagnostic_findings}}.\n\nRecommendations:\n{{recommendations}}"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "На основании представленных данных УЗИ-исследования:\n\nОрган(ы) исследования: {{organ}}\nПоложение и контуры: {{position_and_contours}}\nРазмеры: {{sizes}}\nЭхоструктура: {{echogenicity}}\nОчаговые образования: {{lesions}}\n\nЗаключение:\nУЗ-признаки {{diagnostic_findings}}.\n\nРекомендации:\n{{recommendations}}"
          }
        }
      }
    },
