    "onBoardingIntroDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doglyad is an AI assistant that can help you refine your ultrasound diagnosis.\nThe predicted answer is generated by a specialized LLM model trained on large-scale medical data."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Догляд - это ИИ-ассистент, который поможет уточнить заключение ультра-звукового исследования.\nПредпологаемый ответ генерирует специальная LLM-модель, обученная на большых данных медицинских исследований."
          }
        }
      }
    },
    "onBoardingResearchTypeDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To get started, follow these steps.\nFirst, select the ultrasound type."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Для того чтобы начать работу выполните несколько шагов.\nСперва выберите тип ультразвукового исследования."
          }
        }
      }
    },
    "onBoardingScanDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Next, scan the patient—take a photo of the ultrasound, fill in the medical history and patient details, and submit to see the model's response."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Далее сканируйте пациента - делайте фото ультра-звукового исследования, заполняйте анаимнез, данные пациента и отправляйте чтобы увидеть ответ модели."
          }
        }
      }
    },
